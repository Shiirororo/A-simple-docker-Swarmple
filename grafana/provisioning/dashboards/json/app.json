{
  "title": "App Dashboard",
  "uid": "app-dashboard",
  "schemaVersion": 36,
  "panels": [
    {
      "id": 1,
      "title": "CPU Usage (sum)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum(irate(container_cpu_usage_seconds_total{container_label_com_docker_swarm_service_name=\"demo_app\"}[1m]))",
          "legendFormat": "CPU Usage"
        }
      ]
    },
    {
      "id": 2,
      "title": "Container Count",
      "type": "stat",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "count(container_last_seen{container_label_com_docker_swarm_service_name=\"demo_app\"})",
          "legendFormat": "Containers"
        }
      ]
    }
  ],
  "templating": {
    "list": [
      {
        "name": "DS_PROMETHEUS",
        "type": "datasource",
        "pluginId": "prometheus",
        "hide": 2
      }
    ]
  }
}
